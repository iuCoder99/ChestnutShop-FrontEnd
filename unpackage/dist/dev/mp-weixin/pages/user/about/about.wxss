
.about-container.data-v-d6b522c7 {
  background-color: #F8F8F8;
  min-height: 100vh;
}

/* 品牌信息 */
.brand-info.data-v-d6b522c7 {
  position: relative;
  width: 100%;
  height: 400rpx;
  background-color: #000000;
  overflow: hidden;
}
.brand-banner-wrap.data-v-d6b522c7 {
  width: 100%;
  height: 100%;
}
.brand-banner.data-v-d6b522c7 {
  width: 100%;
  height: 100%;
  opacity: 0.85;
}
.brand-overlay.data-v-d6b522c7 {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0) 20%, rgba(0,0,0,0.8) 100%);
}
.brand-content.data-v-d6b522c7 {
  position: absolute;
  left: 40rpx;
  bottom: 40rpx;
  right: 40rpx;
}
.brand-name.data-v-d6b522c7 {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.5);
}
.brand-tag-line.data-v-d6b522c7 {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}
.tag-item.data-v-d6b522c7 {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 1rpx;
}
.tag-divider.data-v-d6b522c7 {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  margin: 0 16rpx;
}
.about-content-body.data-v-d6b522c7 {
  padding: 30rpx 40rpx;
}

/* 品牌价值观 */
.values-grid.data-v-d6b522c7 {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}
.value-item.data-v-d6b522c7 {
  flex: 1;
  background-color: #FFFFFF;
  padding: 30rpx 20rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}
.value-item.data-v-d6b522c7:last-child {
  margin-right: 0;
}
.value-num.data-v-d6b522c7 {
  font-size: 36rpx;
  font-weight: 800;
  color: #F0F0F0;
  font-style: italic;
  margin-bottom: 10rpx;
}
.value-label.data-v-d6b522c7 {
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
}

/* 通用 section 样式 */
.intro-section.data-v-d6b522c7, .contact-section.data-v-d6b522c7 {
  margin-bottom: 30rpx;
  background-color: #FFFFFF;
  padding: 36rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.05);
}
.section-header.data-v-d6b522c7 {
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}
.section-title.data-v-d6b522c7 {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  position: relative;
  padding-left: 24rpx;
}
.section-title.data-v-d6b522c7::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background-color: #000000;
  border-radius: 4rpx;
}

/* 简介内容 */
.intro-content.data-v-d6b522c7 {
  font-size: 28rpx;
  color: #4A4A4A;
  line-height: 1.8;
  text-align: justify;
}

/* 联系方式列表 */
.contact-list.data-v-d6b522c7 {
  display: flex;
  flex-direction: column;
}
.contact-item.data-v-d6b522c7 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  transition: all 0.2s ease;
}
.contact-item.data-v-d6b522c7:active {
  opacity: 0.6;
  background-color: #FAFAFA;
}
.contact-item.data-v-d6b522c7:last-child {
  border-bottom: none;
}
.item-left.data-v-d6b522c7 {
  display: flex;
  align-items: center;
}
.contact-icon.data-v-d6b522c7 {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}
.contact-label.data-v-d6b522c7 {
  font-size: 28rpx;
  color: #666666;
}
.item-right.data-v-d6b522c7 {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-left: 30rpx;
  overflow: hidden;
}
.contact-value.data-v-d6b522c7 {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.copy-tag.data-v-d6b522c7 {
  font-size: 22rpx;
  color: #000000;
  padding: 6rpx 20rpx;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  margin-left: 20rpx;
}
.arrow-icon.data-v-d6b522c7 {
  width: 24rpx;
  height: 24rpx;
  margin-left: 12rpx;
  opacity: 0.3;
}

/* 版权信息 */
.copyright.data-v-d6b522c7 {
  padding: 60rpx 0 100rpx;
  text-align: center;
}
.copyright text.data-v-d6b522c7 {
  font-size: 24rpx;
  color: #BFBFBF;
  letter-spacing: 1rpx;
}
