
.profile-container.data-v-952fae71 {
  min-height: 100vh;
  background-color: #F0F4F7;
  display: flex;
  justify-content: center;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}
.profile-content.data-v-952fae71 {
  width: 100%;
  max-width: 800px;
  position: relative;
}
.profile-header-bg.data-v-952fae71 {
  position: absolute;
  top: -40rpx;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(135deg, #53BAB3 0%, #3a9c95 100%);
  border-radius: 0 0 40rpx 40rpx;
  z-index: 0;
}
.profile-main-card.data-v-952fae71 {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
  margin-top: 40rpx;
}

/* 头像上传区域 */
.avatar-upload-section.data-v-952fae71 {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.avatar-wrapper.data-v-952fae71 {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  padding: 6rpx;
  background: linear-gradient(135deg, #53BAB3 0%, #E8F7F6 100%);
  box-shadow: 0 8rpx 20rpx rgba(83, 186, 179, 0.2);
  cursor: pointer;
  overflow: hidden;
  transition: transform 0.3s ease;
}
.avatar-wrapper.data-v-952fae71:hover {
  transform: scale(1.05);
}
.avatar-img.data-v-952fae71 {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #F5F5F5;
}
.avatar-edit-mask.data-v-952fae71 {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background-color: rgba(0, 0, 0, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.avatar-wrapper:hover .avatar-edit-mask.data-v-952fae71 {
  opacity: 1;
}
.camera-icon.data-v-952fae71 {
  width: 24rpx;
  height: 24rpx;
  filter: brightness(0) invert(1);
}
.edit-text.data-v-952fae71 {
  font-size: 16rpx;
  color: #FFFFFF;
}
.avatar-tip.data-v-952fae71 {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 表单区域 */
.info-form.data-v-952fae71 {
  margin-bottom: 80rpx;
}
.form-group.data-v-952fae71 {
  margin-bottom: 40rpx;
}
.form-label-box.data-v-952fae71 {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.form-label.data-v-952fae71 {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}
.form-required.data-v-952fae71 {
  color: #FF4D4F;
  margin-left: 8rpx;
  font-size: 24rpx;
}
.input-wrapper.data-v-952fae71 {
  display: flex;
  align-items: center;
  background-color: #F9F9F9;
  border-radius: 16rpx;
  padding: 0 30rpx;
  height: 100rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}
.input-wrapper.data-v-952fae71:focus-within {
  background-color: #FFFFFF;
  border-color: #53BAB3;
  box-shadow: 0 4rpx 12rpx rgba(83, 186, 179, 0.1);
}
.input-icon.data-v-952fae71 {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
  opacity: 0.4;
}
.profile-input.data-v-952fae71 {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}
.input-tip.data-v-952fae71 {
  font-size: 22rpx;
  color: #BBBBBB;
  margin-top: 12rpx;
  margin-left: 4rpx;
}

/* 按钮区域 */
.action-section.data-v-952fae71 {
  display: flex;
  justify-content: center;
}
.save-btn-container.data-v-952fae71 {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 400rpx;
}
.custom-save-btn.data-v-952fae71 {
  width: 100%;
  height: 110rpx;
  background: linear-gradient(135deg, #53BAB3 0%, #3a9c95 100%);
  border-radius: 55rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 10rpx 0 40rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 20rpx rgba(83, 186, 179, 0.3);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  border: none;
}
.custom-save-btn.data-v-952fae71:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 14rpx 28rpx rgba(83, 186, 179, 0.4);
}
.custom-save-btn.data-v-952fae71:active {
  transform: scale(0.98);
  opacity: 0.9;
}
.btn-disabled.data-v-952fae71 {
  background: #CCCCCC !important;
  box-shadow: none !important;
  pointer-events: none;
}
.btn-text.data-v-952fae71 {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}
.btn-arrow.data-v-952fae71 {
  width: 90rpx;
  height: 90rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.arrow-img.data-v-952fae71 {
  width: 32rpx;
  height: 32rpx;
  filter: brightness(0) invert(1);
}
.cancel-link.data-v-952fae71 {
  margin-top: 30rpx;
  font-size: 26rpx;
  color: #999999;
  text-decoration: underline;
  cursor: pointer;
}
.cancel-link.data-v-952fae71:hover {
  color: #666666;
}

/* 移动端适配 */
@media screen and (max-width: 750px) {
.profile-container.data-v-952fae71 {
    padding: 20rpx;
}
.profile-main-card.data-v-952fae71 {
    padding: 40rpx 30rpx;
}
}
