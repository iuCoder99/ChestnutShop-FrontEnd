
/* 基础样式 */
.detail-container.data-v-c7dbfb7e {
  background-color: #FFFFFF;
  min-height: 100vh;
  position: relative;
}

/* 产品图片区 */
.product-img-swiper.data-v-c7dbfb7e {
  width: 100%;
  height: 400rpx;
}
.product-img.data-v-c7dbfb7e {
  width: 100%;
  height: 100%;
}

/* 产品信息区 */
.product-info.data-v-c7dbfb7e {
  padding: 20rpx;
}
.product-name.data-v-c7dbfb7e {
  font-size: 20rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.price-container.data-v-c7dbfb7e {
  margin-bottom: 16rpx;
}
.current-price.data-v-c7dbfb7e {
  font-size: 24rpx;
  color: #D4B886;
  font-weight: bold;
}
.enterprise-price.data-v-c7dbfb7e {
  font-size: 14rpx;
  color: #666666;
  margin-left: 16rpx;
}
.stock-status.data-v-c7dbfb7e {
  font-size: 14rpx;
  color: #666666;
  margin-bottom: 20rpx;
}
.stock-warning.data-v-c7dbfb7e {
  color: #F53F3F;
  margin-left: 8rpx;
}
.product-desc.data-v-c7dbfb7e {
  font-size: 16rpx;
  color: #333333;
  line-height: 1.5;
}

/* 规格选择区 */
.spec-container.data-v-c7dbfb7e {
  padding: 20rpx;
  border-top: 1rpx solid #EEEEEE;
}
.spec-label.data-v-c7dbfb7e {
  font-size: 16rpx;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

/* 相关推荐区 */
.related-container.data-v-c7dbfb7e {
  padding: 0 20rpx 100rpx;
}
.section-title.data-v-c7dbfb7e {
  font-size: 20rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}
.related-list.data-v-c7dbfb7e {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.related-item.data-v-c7dbfb7e {
  width: 32%;
}
.related-img.data-v-c7dbfb7e {
  width: 100%;
  height: 120rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}
.related-name.data-v-c7dbfb7e {
  font-size: 14rpx;
  color: #333333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.related-price.data-v-c7dbfb7e {
  font-size: 14rpx;
  color: #D4B886;
  font-weight: bold;
}

/* 底部操作区 */
.bottom-operation.data-v-c7dbfb7e {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #EEEEEE;
  padding: 0 20rpx;
  box-sizing: border-box;
}
.operation-btn.data-v-c7dbfb7e {
  width: 15%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.btn-icon.data-v-c7dbfb7e {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 8rpx;
}
.operation-btn text.data-v-c7dbfb7e {
  font-size: 14rpx;
  color: #333333;
}
.btn-secondary.data-v-c7dbfb7e {
  width: 30%;
  height: 80rpx;
  background-color: #FFFFFF;
  border: 1rpx solid #333333;
  color: #333333;
  border-radius: 8rpx;
  font-size: 16rpx;
  margin: 0 10rpx;
}
.btn-primary.data-v-c7dbfb7e {
  width: 35%;
  height: 80rpx;
  background-color: #D4B886;
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 16rpx;
}
