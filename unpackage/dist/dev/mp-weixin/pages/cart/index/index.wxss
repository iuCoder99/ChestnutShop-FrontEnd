
/* 基础样式 */
.cart-container.data-v-4d2c878e {
  background-color: #FFFFFF;
  min-height: 100vh;
}
.cart-content-body.data-v-4d2c878e {
  padding: 20rpx;
}

/* 空购物车 */
.empty-cart.data-v-4d2c878e {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}
.empty-img.data-v-4d2c878e {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}
.empty-text.data-v-4d2c878e {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 30rpx;
}
.go-shopping-btn.data-v-4d2c878e {
  width: 200rpx;
  height: 80rpx;
  background-color: #D4B886;
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 购物车列表 */
.cart-header.data-v-4d2c878e {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  height: 80rpx;
}
.header-left.data-v-4d2c878e {
  display: flex;
  align-items: center;
}
.all-select-text.data-v-4d2c878e {
  font-size: 28rpx;
  color: #333333;
  margin-left: 8rpx;
}
.batch-delete-btn.data-v-4d2c878e {
  color: #F53F3F;
  font-size: 28rpx;
  background-color: transparent;
  padding: 0;
  margin: 0;
}
.edit-actions.data-v-4d2c878e {
  display: flex;
  align-items: center;
}
.cancel-edit-btn.data-v-4d2c878e {
  font-size: 28rpx;
  color: #666666;
  background-color: transparent;
  margin-right: 20rpx;
}
.confirm-delete-btn.data-v-4d2c878e {
  font-size: 28rpx;
  color: #F53F3F;
  background-color: transparent;
}

/* 购物车商品项 */
.cart-item.data-v-4d2c878e {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-bottom: 1rpx solid #EEEEEE;
}
.cart-item-img.data-v-4d2c878e {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin: 0 16rpx;
}
.cart-item-info.data-v-4d2c878e {
  flex: 1;
}
.cart-item-name.data-v-4d2c878e {
  font-size: 28rpx;
  color: #333333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.cart-item-spec.data-v-4d2c878e {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}
.item-bottom.data-v-4d2c878e {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.cart-item-price.data-v-4d2c878e {
  font-size: 32rpx;
  color: #D4B886;
  font-weight: bold;
}
.quantity-control.data-v-4d2c878e {
  display: flex;
  align-items: center;
}
.quantity-btn.data-v-4d2c878e {
  width: 50rpx;
  height: 50rpx;
  background-color: #f5f5f5;
  color: #333333;
  font-size: 32rpx;
  padding: 0;
  display: flex;
  justify-content: center;
  align-items: center;
}
.quantity-input.data-v-4d2c878e {
  width: 80rpx;
  height: 50rpx;
  text-align: center;
  border: 1rpx solid #EEEEEE;
  margin: 0 8rpx;
  font-size: 28rpx;
}
.item-delete-btn.data-v-4d2c878e {
  color: #F53F3F;
  font-size: 28rpx;
  background-color: transparent;
  margin-left: 16rpx;
}

/* 底部结算 */
.cart-footer.data-v-4d2c878e {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  border-top: 1rpx solid #EEEEEE;
  box-sizing: border-box;
}
.total-info.data-v-4d2c878e {
  display: flex;
  align-items: center;
}
.total-text.data-v-4d2c878e {
  font-size: 28rpx;
  color: #333333;
  margin-right: 8rpx;
}
.total-price.data-v-4d2c878e {
  font-size: 36rpx;
  color: #D4B886;
  font-weight: bold;
  margin-right: 16rpx;
}
.total-count.data-v-4d2c878e {
  font-size: 24rpx;
  color: #666666;
}
.footer-btns.data-v-4d2c878e {
  display: flex;
  align-items: center;
}
.cancel-btn.data-v-4d2c878e, .save-btn.data-v-4d2c878e {
  width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
  opacity: 0.4;
  padding: 0;
  border: 1rpx solid #D4B886;
  background-color: #FFFFFF;
  color: #D4B886;
}
.save-btn.data-v-4d2c878e {
  background-color: #D4B886;
  color: #FFFFFF;
}
.cancel-btn.active.data-v-4d2c878e, .save-btn.active.data-v-4d2c878e {
  opacity: 1;
}
.settle-btn.data-v-4d2c878e {
  width: 160rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #D4B886;
  color: #FFFFFF;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.settle-btn.data-v-4d2c878e:disabled {
  background-color: #E8D7BF;
}
