
/* 基础样式 */
.cart-container.data-v-4d2c878e {
  background-color: #f8f8f8; /* 改为浅灰色背景，增加层次感 */
  min-height: 100vh;
  padding-bottom: 120rpx; /* 为固定底栏预留空间 */
}
.cart-content-body.data-v-4d2c878e {
  padding: 24rpx;
}

/* 优惠券模块 */
.coupon-section.data-v-4d2c878e {
  background-color: #ffffff;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.coupon-left.data-v-4d2c878e {
  display: flex;
  align-items: center;
}
.coupon-label.data-v-4d2c878e {
  background: linear-gradient(135deg, #ff6b6b, #ff3b30);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 16rpx;
}
.coupon-tip.data-v-4d2c878e {
  font-size: 26rpx;
  color: #333;
}
.coupon-right.data-v-4d2c878e {
  display: flex;
  align-items: center;
}
.coupon-action.data-v-4d2c878e {
  font-size: 24rpx;
  color: #ff3b30;
  margin-right: 8rpx;
}

/* 空购物车 */
.empty-cart.data-v-4d2c878e {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 150rpx;
}
.empty-content.data-v-4d2c878e {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-img.data-v-4d2c878e {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}
.empty-text.data-v-4d2c878e {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}
.empty-subtext.data-v-4d2c878e {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.go-shopping-btn.data-v-4d2c878e {
  width: 280rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #e0c596, #d4b886);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 10rpx 20rpx rgba(212, 184, 134, 0.3);
  transition: all 0.3s;
}
.go-shopping-btn.data-v-4d2c878e:active {
  transform: scale(0.95);
  box-shadow: 0 5rpx 10rpx rgba(212, 184, 134, 0.2);
}

/* 购物车头部 */
.cart-header.data-v-4d2c878e {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 10rpx;
}
.all-select-wrapper.data-v-4d2c878e {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}
/* 自定义复选框 */
.custom-checkbox.data-v-4d2c878e {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s;
  background-color: #fff;
}
.custom-checkbox.checked.data-v-4d2c878e {
  background-color: #d4b886;
  border-color: #d4b886;
}
.custom-checkbox.disabled.data-v-4d2c878e {
  background-color: #f5f5f5;
  border-color: #eee;
}
.checkbox-inner.data-v-4d2c878e {
  width: 20rpx;
  height: 10rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg);
  margin-top: -4rpx;
}
.all-select-text.data-v-4d2c878e {
  font-size: 28rpx;
  color: #333;
  margin-left: 12rpx;
  font-weight: 500;
}

/* 批量删除按钮重设计 */
.batch-delete-btn.data-v-4d2c878e {
  font-size: 24rpx;
  color: #999;
  background: transparent;
  padding: 0;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  display: flex;
  align-items: center;
  transition: all 0.3s;
  border: none;
}
.batch-delete-btn.btn-active.data-v-4d2c878e {
  color: #ff3b30;
  font-weight: bold;
}
.btn-badge.data-v-4d2c878e {
  margin-left: 4rpx;
}
.batch-delete-btn.data-v-4d2c878e:active {
  opacity: 0.7;
}

/* 商品卡片 */
.cart-item-card.data-v-4d2c878e {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
  transition: all 0.2s;
  position: relative;
}
.item-disabled.data-v-4d2c878e {
  opacity: 0.6;
}
.item-checkbox.data-v-4d2c878e {
  padding: 20rpx;
  margin: -20rpx;
  margin-right: 10rpx;
}
.item-main-content.data-v-4d2c878e {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}
.image-wrapper.data-v-4d2c878e {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
}
.cart-item-img.data-v-4d2c878e {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}
.stock-mask.data-v-4d2c878e {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 12rpx;
}
.cart-item-info.data-v-4d2c878e {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 160rpx;
  min-width: 0;
}
.cart-item-name.data-v-4d2c878e {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.cart-item-spec-tag.data-v-4d2c878e {
  background-color: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  margin: 8rpx 0;
}
.spec-text.data-v-4d2c878e {
  font-size: 22rpx;
  color: #999;
}
.item-price-row.data-v-4d2c878e {
  display: flex;
  align-items: baseline;
}
.cart-item-price.data-v-4d2c878e {
  font-size: 34rpx;
  color: #d4b886;
  font-weight: bold;
}
.item-right-actions.data-v-4d2c878e {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  height: 160rpx;
  padding-left: 20rpx;
}
.quantity-control.data-v-4d2c878e {
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 24rpx;
  padding: 2rpx;
}
.quantity-btn.data-v-4d2c878e {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}
.quantity-btn.disabled.data-v-4d2c878e {
  color: #ccc;
}
.quantity-input.data-v-4d2c878e {
  width: 50rpx;
  height: 40rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
}
.single-delete-action.data-v-4d2c878e {
  font-size: 24rpx;
  color: #ff3b30;
  padding: 10rpx 20rpx;
  background-color: #fff0f0;
  border-radius: 20rpx;
  transition: all 0.2s;
}
.single-delete-action.data-v-4d2c878e:active {
  background-color: #ffcccc;
  transform: scale(0.9);
}

/* 底部结算栏 */
.cart-footer.data-v-4d2c878e {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.98);
  -webkit-backdrop-filter: blur(10px);
          backdrop-filter: blur(10px);
  display: flex;
