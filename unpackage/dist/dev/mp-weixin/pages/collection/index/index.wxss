
.collection-container.data-v-a3216c10 {
  background-color: #F8F8F8;
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 120rpx; /* 为底部操作栏留出空间 */
}

/* 顶部管理栏 */
.header-bar.data-v-a3216c10 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 10rpx 20rpx 10rpx;
  background-color: #F8F8F8;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
}
.total-count.data-v-a3216c10 {
  font-size: 26rpx;
  color: #666666;
}
.manage-btn.data-v-a3216c10 {
  font-size: 28rpx;
  color: #333333;
  padding: 10rpx 20rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

/* 收藏列表 */
.collection-list.data-v-a3216c10 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.collection-item.data-v-a3216c10 {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
  transition: all 0.3s;
}
.collection-item.data-v-a3216c10:active {
  background-color: #FAFAFA;
}

/* 勾选框样式 */
.checkbox-wrapper.data-v-a3216c10 {
  margin-right: 20rpx;
  display: flex;
  align-items: center;
}
.checkbox.data-v-a3216c10 {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #CCCCCC;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  transition: all 0.2s;
}
.checkbox.checked.data-v-a3216c10 {
  background-color: #FF5000;
  border-color: #FF5000;
}
.check-icon.data-v-a3216c10 {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
}
.item-img.data-v-a3216c10 {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  background-color: #F5F5F5;
  flex-shrink: 0;
}
.item-info.data-v-a3216c10 {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 180rpx;
  overflow: hidden;
  padding-top: 4rpx;
  padding-bottom: 4rpx;
}
.item-name.data-v-a3216c10 {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 8rpx;
}
.item-spec.data-v-a3216c10 {
  font-size: 24rpx;
  color: #999999;
  background-color: #F8F8F8;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  align-self: flex-start;
  margin-bottom: auto;
}
.price-row.data-v-a3216c10 {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}
.item-price.data-v-a3216c10 {
  font-size: 36rpx;
  color: #FF5000;
  font-weight: bold;
  margin-right: 12rpx;
}
.enterprise-tag.data-v-a3216c10 {
  font-size: 20rpx;
  color: #FF5000;
  background-color: #FFF0E9;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  border: 1rpx solid #FF5000;
}
.item-operation.data-v-a3216c10 {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  height: 180rpx;
  margin-left: 20rpx;
  padding-top: 4rpx;
  padding-bottom: 4rpx;
}
.buy-btn.data-v-a3216c10 {
  width: 140rpx;
  height: 60rpx;
  background: linear-gradient(90deg, #FF9000, #FF5000);
  color: #FFFFFF;
  border-radius: 30rpx;
  font-size: 26rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  border: none;
  box-shadow: 0 4rpx 10rpx rgba(255, 80, 0, 0.2);
}
.collect-btn.data-v-a3216c10 {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F8F8F8;
  border-radius: 50%;
}
.collect-icon.data-v-a3216c10 {
  font-size: 32rpx;
}

/* 底部操作栏 */
.bottom-bar.data-v-a3216c10 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}
.select-all.data-v-a3216c10 {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333333;
}
.select-text.data-v-a3216c10 {
  margin-left: 16rpx;
}
.action-buttons.data-v-a3216c10 {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.cancel-btn.data-v-a3216c10 {
  width: 140rpx;
  height: 72rpx;
  background-color: #F5F5F5;
  color: #666666;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  border: none;
}
.delete-btn.data-v-a3216c10 {
  width: 180rpx;
  height: 72rpx;
  background: linear-gradient(90deg, #FF9000, #FF5000);
  color: #FFFFFF;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  border: none;
  transition: all 0.3s;
}
.delete-btn.disabled.data-v-a3216c10 {
  background: #CCCCCC;
  color: #FFFFFF;
  opacity: 0.8;
}

/* 空收藏状态 */
.empty-collection.data-v-a3216c10 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.empty-icon.data-v-a3216c10 {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  opacity: 0.8;
}
.empty-text.data-v-a3216c10 {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 60rpx;
}
.go-shop-btn.data-v-a3216c10 {
  width: 280rpx;
  height: 88rpx;
  background: linear-gradient(90deg, #D4B886, #C0A060);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(212, 184, 134, 0.3);
}
.loading-state.data-v-a3216c10 {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}
.loading-text.data-v-a3216c10 {
  font-size: 26rpx;
  color: #999999;
}
