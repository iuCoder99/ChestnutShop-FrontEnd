<view class="address-list-container data-v-355d0d83"><view class="header data-v-355d0d83"><view class="header-left data-v-355d0d83"><text class="header-title data-v-355d0d83">我的收货地址</text><text class="header-subtitle data-v-355d0d83">管理您的配送信息</text></view><button class="add-btn data-v-355d0d83" bindtap="{{a}}" hover-class="btn-hover"><text class="add-icon data-v-355d0d83">+</text><text class="data-v-355d0d83">新增地址</text></button></view><view wx:if="{{b}}" class="address-grid data-v-355d0d83"><view wx:for="{{c}}" wx:for-item="item" wx:key="m" class="address-card data-v-355d0d83" bindtap="{{item.n}}"><view class="card-header data-v-355d0d83"><view class="user-info data-v-355d0d83"><text class="address-name data-v-355d0d83">{{item.a}}</text><text class="address-phone data-v-355d0d83">{{item.b}}</text></view><view wx:if="{{item.c}}" class="address-default data-v-355d0d83">默认</view></view><view class="card-body data-v-355d0d83"><text class="address-detail data-v-355d0d83">{{item.d}}{{item.e}}{{item.f}} {{item.g}}</text></view><view class="card-footer data-v-355d0d83" catchtap="{{item.l}}"><view wx:if="{{item.h}}" class="footer-left data-v-355d0d83"><image src="{{item.i}}" class="select-icon data-v-355d0d83"></image><text class="select-text data-v-355d0d83">当前选中</text></view><view class="footer-right data-v-355d0d83"><view class="op-btn edit data-v-355d0d83" catchtap="{{item.j}}"><text class="op-text data-v-355d0d83">编辑</text></view><view class="op-btn delete data-v-355d0d83" catchtap="{{item.k}}"><text class="op-text data-v-355d0d83">删除</text></view></view></view></view></view><view wx:else class="empty-address data-v-355d0d83"><image src="{{d}}" class="empty-img data-v-355d0d83"></image><text class="empty-text data-v-355d0d83">暂无收货地址</text><button class="add-first-btn data-v-355d0d83" bindtap="{{e}}">添加我的第一个地址</button></view></view>