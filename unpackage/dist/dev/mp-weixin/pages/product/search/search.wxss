
.search-container.data-v-f1fe5789 {
  background-color: #F8F8F8;
  min-height: 100vh;
  padding-top: 100rpx; /* 为固定顶部留出空间 */
}

/* 搜索栏 */
.search-header.data-v-f1fe5789 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.search-bar.data-v-f1fe5789 {
  flex: 1;
  height: 64rpx;
  background-color: #F5F5F5;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  margin-right: 20rpx;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
  border: 1rpx solid transparent;
}
.search-bar.focused.data-v-f1fe5789 {
  background-color: #FFFFFF;
  border-color: #000000;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}
.search-icon.data-v-f1fe5789 {
  width: 28rpx;
  height: 28rpx;
  margin-right: 16rpx;
  transition: transform 0.3s ease;
}
.search-bar.focused .search-icon.data-v-f1fe5789 {
  transform: scale(1.1);
}
.search-input.data-v-f1fe5789 {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.clear-btn.data-v-f1fe5789 {
  font-size: 32rpx;
  color: #999;
  padding: 0 10rpx;
}
.cancel-text.data-v-f1fe5789 {
  font-size: 28rpx;
  color: #666;
  transition: color 0.3s ease;
}
.cancel-text.data-v-f1fe5789:active {
  color: #000000;
}

/* 通用板块样式 */
.section.data-v-f1fe5789 {
  background-color: #FFFFFF;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.section-header.data-v-f1fe5789 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title.data-v-f1fe5789 {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}
.header-actions.data-v-f1fe5789 {
  display: flex;
  align-items: center;
}
.action-icon.data-v-f1fe5789 {
  width: 32rpx;
  height: 32rpx;
  margin-left: 30rpx;
  transition: transform 0.2s ease;
}
.action-icon.data-v-f1fe5789:active {
  transform: scale(0.9);
}
.keyword-list.data-v-f1fe5789 {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.keyword-tag.data-v-f1fe5789 {
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #F5F5F5;
  position: relative;
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}
.keyword-tag.data-v-f1fe5789:active {
  background-color: #EEEEEE;
  transform: scale(0.95);
}
.keyword-tag.hot.data-v-f1fe5789 {
  color: #FF6B00;
  background-color: #FFF0E5;
}
.keyword-tag.hot.data-v-f1fe5789:active {
  background-color: #FFE0CC;
}
.delete-tag-btn.data-v-f1fe5789 {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: #999;
  line-height: 1;
}
.hidden-history-tip.data-v-f1fe5789 {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 20rpx 0;
}

/* 猜你喜欢 */
.guess-like-container.data-v-f1fe5789 {
  padding: 20rpx;
}
.section-title-center.data-v-f1fe5789 {
  text-align: center;
  margin: 30rpx 0;
  color: #D4B886;
  font-size: 28rpx;
  font-weight: bold;
}

/* 排序栏 */
.sort-bar.data-v-f1fe5789 {
  display: flex;
  justify-content: space-around;
  background-color: #FFFFFF;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EEE;
  position: -webkit-sticky;
  position: sticky;
  top: 100rpx; /* 适配搜索栏高度 */
  z-index: 998;
}
.sort-item.data-v-f1fe5789 {
  padding: 10rpx 20rpx;
  transition: all 0.2s ease;
}
.sort-item.data-v-f1fe5789:active {
  opacity: 0.7;
}
.sort-text.data-v-f1fe5789 {
  font-size: 28rpx;
  color: #666;
}
.sort-item.active .sort-text.data-v-f1fe5789 {
  color: #D4B886;
  font-weight: bold;
}

/* 产品列表 */
.product-list.data-v-f1fe5789 {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  padding: 20rpx;
}
.product-item.data-v-f1fe5789 {
  width: 18.8%;
  background-color: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  margin-right: 1.5%;
  box-sizing: border-box;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
  position: relative;
  top: 0;
}
.product-item.data-v-f1fe5789:nth-child(5n) {
  margin-right: 0;
}

/* PC端悬停效果 */
@media (min-width: 1024px) {
.product-item.data-v-f1fe5789:hover {
    transform: translateY(-8rpx) scale(1.02);
    box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
    border-color: #000000;
    z-index: 2;
}
.product-item:hover .product-img.data-v-f1fe5789 {
    transform: scale(1.05);
}
}

/* 移动端点击效果 */
.product-item-hover.data-v-f1fe5789 {
  background-color: #F9F9F9;
  transform: scale(0.98);
}
.product-img.data-v-f1fe5789 {
  width: 100%;
  height: 350rpx;
  background-color: #F9F9F9;
  transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
}
.product-info.data-v-f1fe5789 {
  padding: 10rpx;
}
.product-name.data-v-f1fe5789 {
  font-size: 22rpx;
  color: #000000;
  font-weight: bold;
  margin-bottom: 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.2;
}
.product-sellPoint.data-v-f1fe5789 {
  font-size: 18rpx;
  color: #999999;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.product-price.data-v-f1fe5789 {
  font-size: 24rpx;
  color: #000000;
  font-weight: 900;
  font-family: 'DIN Alternate', 'PingFang SC', sans-serif;
}
.enterprise-tag.data-v-f1fe5789 {
  display: inline-block;
  font-size: 14rpx;
  color: #FFFFFF;
  background-color: #000000;
  padding: 1rpx 4rpx;
  border-radius: 2rpx;
  margin-left: 4rpx;
  vertical-align: middle;
}

/* 状态展示 */
.empty-state.data-v-f1fe5789 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}
.empty-img.data-v-f1fe5789 {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}
.empty-text.data-v-f1fe5789 {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.reset-btn.data-v-f1fe5789 {
  background-color: #D4B886;
  color: #FFF;
  font-size: 28rpx;
  padding: 10rpx 40rpx;
  border-radius: 40rpx;
}
.loading-state.data-v-f1fe5789, .load-more.data-v-f1fe5789 {
  text-align: center;
  padding: 30rpx;
}
.loading-text.data-v-f1fe5789, .load-more-text.data-v-f1fe5789 {
  font-size: 24rpx;
  color: #999;
}
