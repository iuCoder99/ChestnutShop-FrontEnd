
.container.data-v-f1cef4ac {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f8f9fa;
  max-width: 1200px;
  margin: 0 auto;
}
.filter-bar.data-v-f1cef4ac {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
  background-color: #fff;
  border-bottom: 1px solid #eee;
  padding: 0;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
}
.filter-item.data-v-f1cef4ac {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  margin-right: 0;
  font-size: 28rpx;
  color: #666;
  cursor: pointer;
  transition: all 0.3s;
  position: relative;
}
.filter-item.data-v-f1cef4ac:hover {
  color: #333;
}
.filter-item.active.data-v-f1cef4ac {
  color: #000;
  font-weight: bold;
}
.filter-item.active.data-v-f1cef4ac::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background-color: #000;
}
.sort-icons.data-v-f1cef4ac {
  display: flex;
  flex-direction: column;
  margin-left: 8rpx;
  font-size: 16rpx;
}
.icon-up.data-v-f1cef4ac, .icon-down.data-v-f1cef4ac {
  line-height: 1;
  color: #ccc;
}
.icon-up.active.data-v-f1cef4ac, .icon-down.active.data-v-f1cef4ac {
  color: #000;
}
.product-scroll.data-v-f1cef4ac {
  flex: 1;
}
.product-list.data-v-f1cef4ac {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 30rpx;
  padding: 30rpx;
}

/* 渐入动画 */
.fade-in.data-v-f1cef4ac {
  animation: fadeIn-f1cef4ac 0.4s ease-out;
}
@keyframes fadeIn-f1cef4ac {
from { opacity: 0; transform: translateY(10rpx);
}
to { opacity: 1; transform: translateY(0);
}
}

/* 骨架屏动画 */
.pulse.data-v-f1cef4ac {
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 37%, #f2f2f2 63%);
  background-size: 400% 100%;
  animation: skeleton-loading-f1cef4ac 1.4s ease infinite;
}
@keyframes skeleton-loading-f1cef4ac {
0% { background-position: 100% 50%;
}
100% { background-position: 0% 50%;
}
}

/* 骨架屏样式 */
.skeleton-list.data-v-f1cef4ac {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}
@media (min-width: 1024px) {
.skeleton-list.data-v-f1cef4ac {
    grid-template-columns: repeat(5, 1fr);
    gap: 30rpx;
    padding: 30rpx;
}
}
.skeleton-item.data-v-f1cef4ac {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}
.skeleton-img.data-v-f1cef4ac {
  width: 100%;
  height: 350rpx;
}
.skeleton-info.data-v-f1cef4ac {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}
.skeleton-name.data-v-f1cef4ac {
  height: 32rpx;
  width: 90%;
  margin-bottom: 15rpx;
  border-radius: 4rpx;
}
.skeleton-desc.data-v-f1cef4ac {
  height: 24rpx;
  width: 70%;
  margin-bottom: 15rpx;
  border-radius: 4rpx;
}
.skeleton-price.data-v-f1cef4ac {
  height: 36rpx;
  width: 40%;
  border-radius: 4rpx;
}

/* 移动端适配 */
@media screen and (max-width: 1023px) {
.product-list.data-v-f1cef4ac {
    grid-template-columns: repeat(2, 1fr);
    gap: 20rpx;
    padding: 20rpx;
}
}
.product-item.data-v-f1cef4ac {
  width: 100%;
  background-color: #fff;
  border-radius: 8px;
  overflow: hidden;
  transition: all 0.3s;
  cursor: pointer;
  border: 1px solid #eee;
  box-sizing: border-box;
}
.product-item.data-v-f1cef4ac:hover {
  transform: translateY(-10px);
  box-shadow: 0 15px 30px rgba(0,0,0,0.1);
  border-color: #eee;
}
.product-img.data-v-f1cef4ac {
  width: 100%;
  height: 350rpx;
  background-color: #f0f0f0;
  object-fit: cover;
}
@media (min-width: 1024px) {
.product-img.data-v-f1cef4ac {
    height: 400rpx;
}
}
.product-info.data-v-f1cef4ac {
  padding: 20rpx;
}
.product-name.data-v-f1cef4ac {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  height: 2.8em;
}
.product-sellPoint.data-v-f1cef4ac {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.product-price.data-v-f1cef4ac {
  font-size: 32rpx;
  color: #000;
  font-weight: bold;
}
.enterprise-tag.data-v-f1cef4ac {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  background-color: #000;
  padding: 2rpx 8rpx;
  margin-left: 10rpx;
  border-radius: 4rpx;
  vertical-align: middle;
}
.empty-state.data-v-f1cef4ac {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  color: #999;
}
.empty-img.data-v-f1cef4ac {
  width: 240rpx;
  margin-bottom: 30rpx;
}
.loading-more.data-v-f1cef4ac, .no-more.data-v-f1cef4ac {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 24rpx;
}

/* 移动端适配 */
@media screen and (max-width: 768px) {
.product-list.data-v-f1cef4ac {
    grid-template-columns: repeat(2, 1fr);
    gap: 20rpx;
    padding: 20rpx;
}
.product-img.data-v-f1cef4ac {
    height: 350rpx;
}
.filter-bar.data-v-f1cef4ac {
    padding: 0 20rpx;
}
.filter-item.data-v-f1cef4ac {
    margin-right: 30rpx;
    font-size: 26rpx;
}
}
