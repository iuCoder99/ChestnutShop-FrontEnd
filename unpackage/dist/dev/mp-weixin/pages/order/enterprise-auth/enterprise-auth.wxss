
.enterprise-auth-container.data-v-d5bc8601 {
  background-color: #F8F8F8;
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

/* 认证说明 */
.auth-desc.data-v-d5bc8601 {
  margin-bottom: 30rpx;
  padding: 24rpx;
  background-color: #FFF8E1;
  border-radius: 12rpx;
}
.desc-text.data-v-d5bc8601 {
  font-size: 26rpx;
  color: #D4B886;
  line-height: 1.6;
}

/* 认证表单 */
.auth-card.data-v-d5bc8601 {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.form-item.data-v-d5bc8601 {
  margin-bottom: 40rpx;
}
.form-item.data-v-d5bc8601:last-child {
  margin-bottom: 0;
}
.form-label.data-v-d5bc8601 {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}
.form-label.required.data-v-d5bc8601::after {
  content: '*';
  color: #F53F3F;
  margin-left: 4rpx;
}
.form-input.data-v-d5bc8601 {
  width: 100%;
  height: 88rpx;
  padding: 0 20rpx;
  background-color: #F9F9F9;
  border: 1rpx solid #EEEEEE;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}
.form-hint-error.data-v-d5bc8601 {
  font-size: 24rpx;
  color: #F53F3F;
  margin-top: 12rpx;
}

/* 上传区域 */
.upload-container.data-v-d5bc8601 {
  width: 100%;
  height: 360rpx;
  background-color: #F9F9F9;
  border: 2rpx dashed #DDDDDD;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.upload-img.data-v-d5bc8601 {
  width: 100%;
  height: 100%;
}
.upload-icon.data-v-d5bc8601 {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}
.upload-text.data-v-d5bc8601 {
  font-size: 26rpx;
  color: #999999;
}
.upload-hint.data-v-d5bc8601 {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #999999;
}

/* 提交按钮 */
.footer-btn-box.data-v-d5bc8601 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx 40rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.submit-btn.data-v-d5bc8601 {
  width: 100%;
  height: 88rpx;
  background-color: #D4B886;
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.submit-btn.data-v-d5bc8601:active {
  opacity: 0.8;
}
.submit-btn.data-v-d5bc8601:disabled {
  background-color: #E8D7BF;
}
