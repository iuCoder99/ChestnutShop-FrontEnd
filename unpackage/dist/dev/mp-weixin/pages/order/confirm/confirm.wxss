
.confirm-container.data-v-3ade02a2 {
  min-height: 100vh;
  background-color: #F5F6F7;
  padding: 20rpx 24rpx 120rpx;
  box-sizing: border-box;
}

/* 卡片通用样式 */
.card.data-v-3ade02a2 {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

/* 地址区域 */
.address-section.data-v-3ade02a2 {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
}
.address-content.data-v-3ade02a2 {
  padding: 30rpx 24rpx;
  position: relative;
}
.address-header.data-v-3ade02a2 {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.address-tag.data-v-3ade02a2 {
  background-color: #D4B886;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}
.address-location.data-v-3ade02a2 {
  font-size: 26rpx;
  color: #666;
}
.address-detail-row.data-v-3ade02a2 {
  margin-bottom: 16rpx;
}
.address-detail.data-v-3ade02a2 {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}
.address-user.data-v-3ade02a2 {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}
.user-name.data-v-3ade02a2 {
  margin-right: 20rpx;
}
.no-address.data-v-3ade02a2 {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #333;
  font-size: 30rpx;
  font-weight: 500;
}
.add-address-icon.data-v-3ade02a2 {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #D4B886;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 32rpx;
  line-height: 1;
}
.arrow-icon.data-v-3ade02a2 {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}
.address-border.data-v-3ade02a2 {
  height: 6rpx;
  background-image: repeating-linear-gradient(
    45deg,
    #D4B886 0,
    #D4B886 20rpx,
    #fff 20rpx,
    #fff 30rpx,
    #333 30rpx,
    #333 50rpx,
    #fff 50rpx,
    #fff 60rpx
  );
  width: 100%;
}

/* 商品列表 */
.goods-item.data-v-3ade02a2 {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.goods-item.data-v-3ade02a2:last-child {
  border-bottom: none;
}
.goods-img.data-v-3ade02a2 {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  margin-right: 24rpx;
}
.goods-info.data-v-3ade02a2 {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
}
.goods-title-row.data-v-3ade02a2 {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.goods-name.data-v-3ade02a2 {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  flex: 1;
  margin-right: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.goods-price.data-v-3ade02a2 {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}
.goods-spec-row.data-v-3ade02a2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.goods-spec.data-v-3ade02a2 {
  font-size: 24rpx;
  color: #999;
  background-color: #f9f9f9;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.goods-count.data-v-3ade02a2 {
  font-size: 26rpx;
  color: #999;
}

/* 单元格样式 */
.cell-item.data-v-3ade02a2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-top: 1rpx solid #f5f5f5;
}
.cell-label.data-v-3ade02a2 {
  font-size: 28rpx;
