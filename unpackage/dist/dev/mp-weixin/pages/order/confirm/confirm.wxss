  text-align: right;
}
.cell-value.data-v-3ade02a2 {
  font-size: 28rpx;
  color: #666;
}
.remark-input.data-v-3ade02a2 {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}
.placeholder-style.data-v-3ade02a2 {
  color: #999;
}

/* 费用明细 */
.fee-row.data-v-3ade02a2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.fee-label.data-v-3ade02a2 {
  font-size: 28rpx;
  color: #666;
}
.fee-value.data-v-3ade02a2 {
  font-size: 28rpx;
  color: #333;
}
.red-text.data-v-3ade02a2 {
