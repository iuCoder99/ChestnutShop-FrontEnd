/* 底部栏 */
.submit-bar.data-v-3ade02a2 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 99;
}
.total-info.data-v-3ade02a2 {
  display: flex;
  align-items: baseline;
}
.total-text.data-v-3ade02a2 {
