  color: #D4B886;
  font-weight: bold;
}
.submit-btn.data-v-3ade02a2 {
  margin: 0;
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, #EED5A5 0%, #D4B886 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 184, 134, 0.4);
}
.submit-btn[disabled].data-v-3ade02a2 {
  background: #ccc;
  box-shadow: none;
  color: #fff;
}
