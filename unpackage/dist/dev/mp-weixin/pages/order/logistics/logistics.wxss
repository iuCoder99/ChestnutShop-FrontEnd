
.logistics-container.data-v-afa15dc2 {
  background-color: #FFFFFF;
  min-height: 100vh;
  padding: 20rpx;
  position: relative;
}

/* 页面头部 */
.page-header.data-v-afa15dc2 {
  position: relative;
  text-align: center;
  margin-bottom: 30rpx;
  padding-top: 10rpx;
}
.header-title.data-v-afa15dc2 {
  font-size: 20rpx;
  font-weight: bold;
  color: #333333;
}
.back-btn.data-v-afa15dc2 {
  position: absolute;
  left: 0;
  top: 10rpx;
  background-color: transparent;
  padding: 0;
  display: flex;
  align-items: center;
}
.back-icon.data-v-afa15dc2 {
  width: 24rpx;
  height: 24rpx;
  color: #333333;
}

/* 物流基本信息 */
.logistics-base.data-v-afa15dc2 {
  background-color: #F9F9F9;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
}
.logistics-company.data-v-afa15dc2, .logistics-no.data-v-afa15dc2 {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.logistics-company.data-v-afa15dc2:last-child, .logistics-no.data-v-afa15dc2:last-child {
  margin-bottom: 0;
}
.base-label.data-v-afa15dc2 {
  font-size: 14rpx;
  color: #666666;
  width: 120rpx;
}
.base-value.data-v-afa15dc2 {
  font-size: 14rpx;
  color: #333333;
  flex: 1;
}
.copy-btn.data-v-afa15dc2 {
  font-size: 12rpx;
  color: #D4B886;
  background-color: transparent;
  padding: 0 8rpx;
}

/* 物流状态提示 */
.logistics-status.data-v-afa15dc2 {
  margin-bottom: 20rpx;
  padding: 12rpx;
  background-color: #FFF8E1;
  border-radius: 8rpx;
}
.status-text.data-v-afa15dc2 {
  font-size: 14rpx;
  color: #D4B886;
  display: block;
  text-align: center;
}

/* 物流时间轴 */
.logistics-timeline.data-v-afa15dc2 {
  padding-left: 16rpx;
}
.timeline-item.data-v-afa15dc2 {
  display: flex;
  margin-bottom: 24rpx;
  position: relative;
}
.timeline-node.data-v-afa15dc2 {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 16rpx;
}
.node-dot.data-v-afa15dc2 {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #EEEEEE;
  position: relative;
  z-index: 2;
}
.timeline-item.active .node-dot.data-v-afa15dc2 {
  background-color: #D4B886;
}
.node-line.data-v-afa15dc2 {
  width: 2rpx;
  flex: 1;
  background-color: #EEEEEE;
  margin-top: -2rpx;
}
.timeline-content.data-v-afa15dc2 {
  flex: 1;
  padding-bottom: 24rpx;
  border-bottom: 1rpx dashed #EEEEEE;
}
.timeline-item:last-child .timeline-content.data-v-afa15dc2 {
  border-bottom: none;
  padding-bottom: 0;
}
.content-desc.data-v-afa15dc2 {
  font-size: 16rpx;
  color: #333333;
  margin-bottom: 8rpx;
  display: block;
}
.timeline-item.active .content-desc.data-v-afa15dc2 {
  font-weight: bold;
  color: #D4B886;
}
.content-time.data-v-afa15dc2 {
  font-size: 12rpx;
  color: #999999;
}

/* 无物流信息状态 */
.empty-logistics.data-v-afa15dc2 {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}
.empty-img.data-v-afa15dc2 {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}
.empty-text.data-v-afa15dc2 {
  font-size: 16rpx;
  color: #666666;
  margin-bottom: 8rpx;
}
.empty-desc.data-v-afa15dc2 {
  font-size: 14rpx;
  color: #999999;
  margin-bottom: 30rpx;
}
.contact-btn.data-v-afa15dc2 {
  width: 200rpx;
  height: 80rpx;
  background-color: #D4B886;
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 16rpx;
}
