  margin-bottom: 30rpx;
}
.status-pending-pay.data-v-78cad3ff {
  background-color: #FFF1F0;
  color: #F53F3F;
}
.status-pending-confirm.data-v-78cad3ff {
  background-color: #FFF7E6;
  color: #FF7D00;
}
.status-pending-ship.data-v-78cad3ff {
