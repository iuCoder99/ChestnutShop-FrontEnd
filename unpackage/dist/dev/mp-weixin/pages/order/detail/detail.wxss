}
.countdown-value.data-v-78cad3ff {
  font-size: 28rpx;
  color: #D4B886;
  font-weight: bold;
}

/* 订单基础信息 */
.order-base-info.data-v-78cad3ff {
  background-color: #F9F9F9;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}
.info-item.data-v-78cad3ff {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.info-item.data-v-78cad3ff:last-child {
  margin-bottom: 0;
}
.info-label.data-v-78cad3ff {
  font-size: 26rpx;
  color: #666666;
  width: 160rpx;
  flex-shrink: 0;
}
.info-value.data-v-78cad3ff {
  font-size: 26rpx;
  color: #333333;
  word-break: break-all;
}

/* 通用 section 样式 */
.goods-section.data-v-78cad3ff, .receipt-section.data-v-78cad3ff, .logistics-section.data-v-78cad3ff, .payment-section.data-v-78cad3ff, .remark-section.data-v-78cad3ff {
  margin-bottom: 30rpx;
}
.section-title.data-v-78cad3ff {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

/* 商品清单 */
.goods-list.data-v-78cad3ff {
  border: 1rpx solid #EEEEEE;
  border-radius: 12rpx;
  overflow: hidden;
}
.goods-item.data-v-78cad3ff {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #EEEEEE;
}
.goods-item.data-v-78cad3ff:last-child {
  border-bottom: none;
}
.goods-img.data-v-78cad3ff {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}
.goods-info.data-v-78cad3ff {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.goods-name.data-v-78cad3ff {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}
.goods-spec.data-v-78cad3ff {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 10rpx;
}
.goods-count-price.data-v-78cad3ff {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.goods-count.data-v-78cad3ff {
  font-size: 24rpx;
  color: #999999;
}
.goods-price.data-v-78cad3ff {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

/* 收货信息 */
.receipt-info.data-v-78cad3ff {
  background-color: #F9F9F9;
  border-radius: 12rpx;
  padding: 24rpx;
}
.receipt-item.data-v-78cad3ff {
  margin-bottom: 16rpx;
}
.receipt-item.data-v-78cad3ff:last-child {
  margin-bottom: 0;
}
.receipt-label.data-v-78cad3ff {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 8rpx;
}
.receipt-value.data-v-78cad3ff {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
}

/* 物流信息 */
.logistics-info.data-v-78cad3ff {
  background-color: #F9F9F9;
  border-radius: 12rpx;
  padding: 24rpx;
}
.logistics-item.data-v-78cad3ff {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}
.logistics-item.data-v-78cad3ff:last-child {
  margin-bottom: 24rpx;
}
.logistics-label.data-v-78cad3ff {
  font-size: 26rpx;
  color: #666666;
  width: 140rpx;
  flex-shrink: 0;
}
.logistics-value.data-v-78cad3ff {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
  word-break: break-all;
}
.copy-btn.data-v-78cad3ff {
  font-size: 24rpx;
  color: #D4B886;
  background-color: transparent;
  padding: 0 10rpx;
  margin: 0;
  line-height: 1.5;
  border: none;
}
.copy-btn.data-v-78cad3ff::after {
  border: none;
}
.logistics-track.data-v-78cad3ff {
  padding: 20rpx 0;
  border-top: 1rpx solid #EEEEEE;
  margin-bottom: 20rpx;
}
.track-item.data-v-78cad3ff {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
  position: relative;
  padding-left: 30rpx;
}
.track-item.data-v-78cad3ff::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 12rpx;
  height: 12rpx;
  background-color: #D4B886;
  border-radius: 50%;
}
.track-item.data-v-78cad3ff:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 5rpx;
  top: 24rpx;
  width: 2rpx;
  height: calc(100% + 8rpx);
  background-color: #EEEEEE;
}
.track-time.data-v-78cad3ff {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}
.track-content.data-v-78cad3ff {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.4;
}
.check-logistics-btn.data-v-78cad3ff {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #FFFFFF;
  border: 1rpx solid #D4B886;
  color: #D4B886;
  border-radius: 36rpx;
  font-size: 26rpx;
}
.no-logistics.data-v-78cad3ff {
  padding: 40rpx;
  text-align: center;
  background-color: #F9F9F9;
  border-radius: 12rpx;
}
.no-logistics-text.data-v-78cad3ff {
  font-size: 26rpx;
  color: #999999;
}

/* 支付信息 */
.payment-info.data-v-78cad3ff {
  background-color: #F9F9F9;
  border-radius: 12rpx;
  padding: 24rpx;
}
.payment-item.data-v-78cad3ff {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.payment-item.data-v-78cad3ff:last-child {
