}
.status-item.active .status-text.data-v-0e562ae0 {
  color: #D4B886;
  font-weight: bold;
  font-size: 30rpx;
}

/* 选中时的底部横条 */
.status-item.active.data-v-0e562ae0::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #D4B886;
  border-radius: 2rpx;
}

